<?xml version="1.0" encoding="UTF-8"?>

<phpunit
        bootstrap="vendor/autoload.php"
        colors="true"
        processIsolation="false"
        stopOnError="false"
        stopOnFailure="false"
>

        <source>
                <include>
                        <directory suffix=".php">src</directory>
                </include>
                <exclude>
                        <directory suffix="Test.php">src</directory>
                </exclude>
        </source>

        <testsuites>
                <testsuite name="RosePHP">
                        <directory suffix="Test.php">src</directory>
                </testsuite>
        </testsuites>
</phpunit>
